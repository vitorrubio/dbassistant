ASPNETCORE_ENVIRONMENT=Development
DBASSISTANT_API_PORT=8080
API_KEY_HEADER_NAME=x-api-key
API_KEY_HEADER_VALUE=CHANGE_ME
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=Northwind
MYSQL_USERNAME=CHANGE_ME
MYSQL_PASSWORD=CHANGE_ME
OPENAI_API_KEY=CHANGE_ME
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CACHE_SQL_PLAN_MINUTES=15
CACHE_SCHEMA_SEARCH_MINUTES=30
SCHEMA_KNOWLEDGE_FILE_PATH=knowledge/schema-index.json
SCHEMA_KNOWLEDGE_EMBEDDINGS_FILE_PATH=knowledge/schema-index.embeddings.json
SCHEMA_KNOWLEDGE_MAX_DOCUMENTS=3
